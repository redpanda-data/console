# syntax=docker/dockerfile:1
# Build stage
FROM golang:alpine AS builder

WORKDIR /app

# Set GOTOOLCHAIN to auto to allow Go to download the required version
ENV GOTOOLCHAIN=auto

# Copy go.mod and go.sum first for better caching
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download

# Copy source code
COPY . .

# For enterprise workspace builds, go.work references .e2e-workspace/console-oss-backend/
# which was temporarily copied into the build context by global-setup.mjs.
# Run a second go mod download to fetch any additional workspace module deps.
RUN --mount=type=cache,target=/go/pkg/mod \
    if [ -f "go.work" ]; then go mod download; fi

# Build the binary (works for both OSS and Enterprise structure)
# OSS: cmd/api/main.go, Enterprise: cmd/main.go
# Cache the Go build cache across builds for faster recompilation.
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    if [ -d "/app/cmd/api" ]; then \
      cd /app/cmd/api && CGO_ENABLED=0 GOOS=linux go build -o /app/console-api .; \
    else \
      cd /app/cmd && CGO_ENABLED=0 GOOS=linux go build -o /app/console-api .; \
    fi

# Runtime stage
FROM alpine:3.21

# Install ca-certificates and wget for HTTPS support and healthcheck
RUN apk --no-cache add ca-certificates wget

WORKDIR /app

# Copy binary from builder
COPY --from=builder /app/console-api .

# Expose the server port (serves both API and frontend)
EXPOSE 3000

# Run the application
ENTRYPOINT ["/app/console-api"]
